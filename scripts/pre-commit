#!/bin/sh

# ANSI Color Codes
BLUE='\033[0;34m'
NC='\033[0m'

# Check if --verify is present in the git command arguments
# Git passes the commit message file, but we can check the parent process
# Or more simply, we check a custom environment variable we can alias.
# However, the most 'Git-native' way for an opt-in is checking an ENV var.

if [ "$VERIFY_COVERAGE" != "true" ]; then
    # Skip silently and fast
    exit 0
fi

echo "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo "🔍  OPT-IN QUALITY GATE: Running Coverage Check..."
echo "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# Run the task - filter out the JVM noise but show our println output
./gradlew testWithCoverage --no-daemon | grep -v "OpenJDK 64-Bit Server VM warning"
RESULT=${PIPESTATUS[0]}

if [ $RESULT -ne 0 ]; then
  echo "\n❌  [COMMIT BLOCKED] Coverage is below 80%."
  exit 1
fi

echo "\n✅  [COMMIT ALLOWED] Quality Gate Passed. 🛡️\n"
exit 0
