#!/bin/sh

# ANSI Color Codes
BLUE='\033[0;34m'
NC='\033[0m'

echo "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo "🔍  PRE-COMMIT QUALITY GATE: Checking Aggregate Coverage..."
echo "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

if [ ! -t 0 ] && [ -n "$IDEA_INITIAL_DIRECTORY" ]; then
    # Only proceed if we are absolutely sure this is the final execution phase.
    # When IntelliJ actually executes the commit, it usually sets these.
    if [ -z "$GIT_PREFIX" ] && [ -z "$GIT_AUTHOR_DATE" ]; then
        exit 0
    fi
fi

# 2. ADDITIONAL SAFETY: Check if we are in a "rebase" or "merge" preview
if [ -d ".git/rebase-merge" ] || [ -d ".git/rebase-apply" ]; then
    exit 0
fi

# Run the task. We use --quiet to ensure the report is the main focus.
./gradlew testWithCoverage --quiet
RESULT=$?

if [ $RESULT -ne 0 ]; then
  echo "\n❌  [COMMIT BLOCKED]"
  echo "Project coverage is below 80%. See report above for gaps."
  echo "To bypass (not recommended): git commit --no-verify\n"
  exit 1
fi

echo "\n✅  [COMMIT ALLOWED]"
echo "Quality standards met. Proceeding...\n"
exit 0
